# MODE: 服务模式，默认 mcp（服务模式）
# cli 模式通过 gateway 命令自动触发，无需手动设置
MODE=mcp

# ---------- Feishu Configuration ----------
# 飞书应用凭证（必需）
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxx

# 连接模式：websocket（默认）或 webhook
FEISHU_CONNECTION_MODE=websocket

# 域名：feishu（国内）或 lark（海外）
FEISHU_DOMAIN=feishu

# Webhook 配置（仅 webhook 模式需要）
# FEISHU_WEBHOOK_PORT=8080
# FEISHU_WEBHOOK_PATH=/webhook

# ---------- OpenCode Configuration ----------
# OpenCode AI 服务配置（必需）
OPENCODE_API_URL=http://127.0.0.1:4096
OPENCODE_MODEL_ID=glm-4.7
OPENCODE_PROVIDER_ID=venus-coding-ai
OPENCODE_TIMEOUT=600000

# 进度通知配置（可选）
# 显示工具执行状态（如：正在执行 xxx 工具）
# PROGRESS_TOOL_STATUS=false
# 显示实时文本输出
# PROGRESS_TEXT_OUTPUT=false

# ---------- MCP HTTP Server Configuration ----------
# MCP HTTP 服务端口（供 OpenCode 连接）
# OpenCode 通过此端口调用网关的 MCP 工具
MCP_HTTP_PORT=3100

# ---------- GitLab Configuration ----------
# GitLab 配置（可选，用于创建 MR）
GITLAB_URL=https://gitlab.com/api/v4
GITLAB_TOKEN=glpat-xxxxxxxx
GITLAB_PROJECT_ID=123

# ---------- Zentao Configuration ----------
# 禅道配置（可选，用于 Bug/任务管理）
# API 地址格式：https://your-zentao/api.php/v1
# 开源版需要 16.5+ 才支持 RESTful API
ZENTAO_BASE_URL=https://your-zentao/api.php/v1

# 认证方式一：Token（推荐）
# ZENTAO_TOKEN=your-api-token

# 认证方式二：账号密码
ZENTAO_ACCOUNT=your-username
ZENTAO_PASSWORD=your-password

# 项目 ID（可选）
ZENTAO_PROJECT_ID=1

# ---------- Lark Official MCP Configuration ----------
# 飞书官方 MCP Server 配置（可选，集成官方飞书能力）
# 使用 @larksuiteoapi/lark-mcp 提供飞书文档、多维表格等能力
# LARK_MCP_APP_ID=cli_xxxxxxxxxxxx
# LARK_MCP_APP_SECRET=xxxxxxxxxxxxxxxxxxxx

# ---------- Third-party MCP Servers ----------
# GitHub MCP（需要 GITHUB_TOKEN）
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
# GITHUB_MCP_ENABLED=true

# GitLab MCP（使用官方 GitLab MCP Server）
# GITLAB_MCP_ENABLED=true

# PostgreSQL MCP
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# POSTGRES_MCP_ENABLED=true

# Filesystem MCP
# FILESYSTEM_MCP_PATH=/path/to/folder
# FILESYSTEM_MCP_ENABLED=true

# 自定义 MCP Servers（JSON 格式）
# CUSTOM_MCP_SERVERS={"custom_tool":{"enabled":true,"command":["npx","-y","my-mcp-server"],"description":"My custom MCP"}}

# ---------- Debug ----------
DEBUG=false