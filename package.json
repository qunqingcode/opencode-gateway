{
  "name": "opencode-gateway",
  "version": "3.1.0",
  "description": "MCP Bridge - 让 AI 在飞书里操作你的 DevOps 工具",
  "main": "dist/index.js",
  "bin": {
    "gateway": "./bin/gateway.js"
  },
  "scripts": {
    "start": "npm run build && node dist/index.js",
    "dev": "ts-node index.ts",
    "dev:watch": "tsc --watch",
    "build": "rimraf dist && tsc",
    "build:watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "rebuild": "npm run clean && npm run build",
    "postinstall": "npm run build && npm link",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.26.0",
    "@opencode-ai/sdk": "^1.2.25",
    "dotenv": "^17.3.1",
    "node-cron": "^4.2.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "jest": "^29.7.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "feishu",
    "lark",
    "gitlab",
    "zentao",
    "mcp",
    "gateway",
    "opencode",
    "ai-agent",
    "mcp-server",
    "websocket"
  ],
  "license": "MIT"
}